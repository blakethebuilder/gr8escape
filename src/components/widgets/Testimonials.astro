---
// ponytail: static testimonials — curated review quotes
// Upgrade: swap to Google Places API for live fetch
---

<div class="testimonials-section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-red-500/10 text-gr8-red text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4">
        <span>⭐</span> Rave Reviews
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-white">What Players <span class="text-gr8-gold">Say</span></h2>
      <p class="text-gray-400 mt-3">Rated <span class="text-gr8-gold font-bold">5★</span> across Google — here's what people are saying</p>
    </div>

    <div class="testimonials-grid">
      {
        [
          {
            quote: "Our first ever escape room — absolutely thrilled we chose Gr8 Escape. Unforgettable, immersive experience from start to finish.",
            name: "Marnus V.",
            rating: 5,
          },
          {
            quote: "So much fun! We did this before dinner on date night and it was brilliant. 10/10 recommend.",
            name: "Samantha N.",
            rating: 5,
          },
          {
            quote: "Highly highly recommend. The staff were awesome — Niki made it such a personalised experience. We'll definitely be back for the other rooms.",
            name: "Previn M.",
            rating: 5,
          },
          {
            quote: "Did 3 rooms as a big family. Staff were helpful, puzzles well thought out and engaging. Absolutely worth the time and money.",
            name: "Azhar B.",
            rating: 5,
          },
        ].map((review) => (
          <div class="testimonial-card">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.rating }, (_, i) => (
                <svg key={i} class="w-5 h-5 text-gr8-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-300 text-sm leading-relaxed mb-4 italic">"{review.quote}"</p>
            <p class="text-white font-semibold text-sm">— {review.name}</p>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-8">
      <a href="https://search.google.com/local/reviews?placeid=" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-400 hover:text-gr8-gold transition-colors text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        See all reviews on Google
      </a>
    </div>
  </div>
</div>

<style is:inline>
  .testimonials-section {
    padding: 5rem 0;
    background: #242424;
    position: relative;
    overflow: hidden;
  }
  .testimonials-section::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.2;
    background-image: radial-gradient(circle, rgba(229,57,53,0.08) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .testimonials-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .testimonial-card {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: all 0.3s;
    position: relative;
  }
  .testimonial-card:hover {
    border-color: #E53935;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(229, 57, 53, 0.15);
  }
</style>
