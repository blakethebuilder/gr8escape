---
// Gr8 Escape footer
---

<footer style="background:#0d0d0d; border-top:1px solid #222">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">

      <!-- Quick Links — LEFT on desktop -->
      <div class="order-1">
        <h3 class="footer-heading">Quick Links</h3>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/rooms">Escape Rooms</a>
          <a href="/murder-mysteries">Murder Mysteries</a>
          <a href="/team-building">Team Building</a>
          <a href="/book">Book Now</a>
          <a href="/rules-faqs">Rules & FAQs</a>
          <a href="/contact">Contact</a>
        </div>
      </div>

      <!-- Contact Info — MIDDLE on desktop -->
      <div class="order-2">
        <h3 class="footer-heading">Contact</h3>
        <div class="footer-links">
          <a href="mailto:info@thegr8escape.co.za">info@thegr8escape.co.za</a>
          <a href="tel:0763620765">076 362 0765</a>
        </div>
        <p class="footer-address">
          Pineslopes Office Park, Block C<br/>
          First Floor, Corner Forest Road &amp; The Straight<br/>
          Fourways, Johannesburg
        </p>
        <div class="footer-social">
          <a href="https://facebook.com/thegr8escapefourways" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
