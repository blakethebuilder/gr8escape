---
// Gr8 Escape custom footer — dark, bold, minimal
---

<footer class="relative overflow-hidden" style="background:#0d0d0d; border-top:1px solid #222">
  <!-- Subtle dot grid -->
  <div class="absolute inset-0 opacity-30" style="background-image:radial-gradient(circle,rgba(229,57,53,0.1) 1px,transparent 1px);background-size:32px 32px"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <img src="/assets/logo-main.png" alt="The Gr8 Escape" class="h-10 mb-4" />
        <p class="text-gray-500 text-sm leading-relaxed">
          South Africa's highest rated Escape Room. Immersive puzzle adventures in Fourways, Johannesburg.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-bold mb-4 uppercase tracking-wider text-xs">Quick Links</h3>
        <div class="flex flex-col gap-3">
          <a href="/" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">Home</a>
          <a href="/rooms" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">Rooms</a>
          <a href="/book" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">Book</a>
          <a href="/rules-faqs" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">Rules & FAQs</a>
          <a href="/contact" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">Contact</a>
        </div>
      </div>

      <!-- Contact & Social -->
      <div>
        <h3 class="text-white font-bold mb-4 uppercase tracking-wider text-xs">Contact</h3>
        <div class="flex flex-col gap-3 mb-6">
          <a href="mailto:info@thegr8escape.co.za" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">info@thegr8escape.co.za</a>
          <a href="tel:0763620765" class="text-gray-400 hover:text-gr8-red transition-colors text-sm">076 362 0765</a>
        </div>
        <div class="flex gap-3">
          <a href="https://facebook.com/thegr8escape" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 transition-all hover:scale-110">
            <svg class="w-5 h-5 text-gray-400 hover:text-gr8-red" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/thegr8escape" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 transition-all hover:scale-110">
            <svg class="w-5 h-5 text-gray-400 hover:text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://tiktok.com/@thegr8escape" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 transition-all hover:scale-110">
            <svg class="w-5 h-5 text-gray-400 hover:text-gr8-red" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center text-gray-600 text-xs">
      &copy; 2026 The Gr8 Escape. All rights reserved.
    </div>
  </div>
</footer>
