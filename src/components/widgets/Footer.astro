        </div>
      </div>

      <!-- Brand / Logo — RIGHT on desktop -->
      <div class="order-3 md:text-right">
        <img src="/assets/logo-main.png" alt="The Gr8 Escape" class="footer-logo" />
        <p class="footer-tagline">South Africa's highest rated Escape Room. Immersive puzzle adventures in Fourways, Johannesburg.</p>
      </div>

    </div>

    <div class="footer-bottom">
      <p>Open daily 09:30 – 18:30 &bull; Fri & Sat until 20:00</p>
      <p>&copy; 2026 The Gr8 Escape &bull; Website by <a href="https://debsdezigns.co.za" target="_blank" rel="noopener noreferrer">Debs Dezigns</a></p>
    </div>
  </div>
</footer>

<style is:inline>
  .footer-heading {
    color: white; font-weight: 700; font-size: 0.72rem;
    text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }
  .footer-links {
    display: flex; flex-direction: column; gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .footer-links a {
    color: #888; font-size: 0.85rem; text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: #E53935; }

  .footer-address {
    color: #666; font-size: 0.8rem; line-height: 1.6;
    margin-bottom: 1rem;
  }

  .footer-social {
    display: flex; gap: 0.75rem;
  }
  .footer-social a {
    width: 36px; height: 36px; border-radius: 8px;
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    color: #777; transition: all 0.2s;
  }
  .footer-social a:hover { background: rgba(229,57,53,0.15); color: #E53935; transform: translateY(-2px); }

  .footer-logo {
    height: 2.25rem; margin-bottom: 0.75rem;
  }
  @media (min-width: 768px) {
    .footer-logo { margin-left: auto; }
  }
  .footer-tagline {
    color: #666; font-size: 0.8rem; line-height: 1.6; max-width: 16rem;
  }
  @media (min-width: 768px) {
    .footer-tagline { margin-left: auto; text-align: right; }
  }

  .footer-bottom {
    margin-top: 2rem; padding-top: 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  .footer-bottom p { color: #555; font-size: 0.72rem; line-height: 1.7; }
  .footer-bottom a { color: #666; text-decoration: none; transition: color 0.2s; }
  .footer-bottom a:hover { color: #E53935; }
</style>
