---
// Gr8 Escape custom header — dark, clean, bold
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<header id="gr8-header" class="fixed top-0 left-0 right-0 z-50" style="background:#0d0d0d; border-bottom:1px solid #222">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/assets/logo-main.png" alt="The Gr8 Escape" class="h-8 md:h-10" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <a href="/" class={`nav-link ${isActive('/') ? 'nav-active' : ''}`}>Home</a>
        <a href="/rooms" class={`nav-link ${isActive('/rooms') ? 'nav-active' : ''}`}>Rooms</a>
        <a href="/murder-mysteries" class={`nav-link ${isActive('/murder-mysteries') ? 'nav-active' : ''}`}>Murder Mysteries</a>
        <a href="/book" class={`nav-link ${isActive('/book') ? 'nav-active' : ''}`}>Book</a>
        <a href="/rules-faqs" class={`nav-link ${isActive('/rules-faqs') ? 'nav-active' : ''}`}>Rules & FAQs</a>
        <a href="/availability" class={`nav-link ${isActive('/availability') ? 'nav-active' : ''}`}>Availability</a>
        <a href="/contact" class={`nav-link ${isActive('/contact') ? 'nav-active' : ''}`}>Contact</a>
      </nav>

      <!-- Book Now & Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a href="/book"
           class="hidden sm:inline-flex items-center px-5 py-2 bg-gr8-red text-white font-bold text-sm rounded-lg hover:bg-red-700 transition-all hover:shadow-lg hover:shadow-red-500/25">
          BOOK NOW!
        </a>
        <button id="gr8-menu-toggle" class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors" aria-label="Toggle menu">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" id="menu-icon-open" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
            <path stroke-linecap="round" id="menu-icon-close" class="hidden" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="gr8-mobile-menu" class="mobile-menu md:hidden border-t border-white/10 pt-4">
      <div class="flex flex-col gap-2 pb-4">
        <a href="/" class={`mobile-nav-link ${isActive('/') ? 'nav-active' : ''}`}>Home</a>
        <a href="/rooms" class={`mobile-nav-link ${isActive('/rooms') ? 'nav-active' : ''}`}>Rooms</a>
        <a href="/murder-mysteries" class={`mobile-nav-link ${isActive('/murder-mysteries') ? 'nav-active' : ''}`}>Murder Mysteries</a>
        <a href="/book" class={`mobile-nav-link ${isActive('/book') ? 'nav-active' : ''}`}>Book</a>
        <a href="/rules-faqs" class={`mobile-nav-link ${isActive('/rules-faqs') ? 'nav-active' : ''}`}>Rules & FAQs</a>
        <a href="/availability" class={`mobile-nav-link ${isActive('/availability') ? 'nav-active' : ''}`}>Availability</a>
        <a href="/contact" class={`mobile-nav-link ${isActive('/contact') ? 'nav-active' : ''}`}>Contact</a>
        <a href="/book" class="btn-gr8 text-center mt-3 py-3">BOOK NOW!</a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20"></div>

<script>
  (() => {
    const toggle = document.getElementById('gr8-menu-toggle');
    const menu = document.getElementById('gr8-mobile-menu');
    const openIcon = document.getElementById('menu-icon-open');
    const closeIcon = document.getElementById('menu-icon-close');
    if (!toggle || !menu) return;

    let isOpen = false;

    toggle.addEventListener('click', () => {
      isOpen = !isOpen;
      if (isOpen) {
        menu.classList.add('mobile-menu-open');
        openIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.remove('mobile-menu-open');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.style.overflow = '';
      }
    });
  })();
</script>

<style is:inline>
  .nav-link {
    padding: 0.5rem 1rem;
    color: #aaa;
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }
  .nav-link:hover { color: white; background: rgba(255,255,255,0.05); }

  .nav-active {
    color: #fff !important;
    background: rgba(229, 57, 53, 0.15);
    position: relative;
  }
  .nav-active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 2px;
    background: #E53935;
    border-radius: 2px;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 1rem;
    color: #ccc;
    font-weight: 500;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }
  .mobile-nav-link:hover { color: white; background: rgba(255,255,255,0.05); }
  .mobile-nav-link.nav-active {
    color: #E53935 !important;
    background: rgba(229, 57, 53, 0.1);
  }
  .mobile-nav-link.nav-active::after { display: none; }

  /* Mobile menu animation */
  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.25s ease;
  }
  .mobile-menu-open {
    max-height: 500px;
    opacity: 1;
  }
</style>
