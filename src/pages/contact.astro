---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative py-24 overflow-hidden" style="background:#0a0a0a">
    <div class="absolute inset-0 overflow-hidden">
      <div class="dot-grid"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 0%, #0a0a0a 70%)"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tight">
        Contact <span class="text-gr8-red">Us</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto">
        We'd love to hear from you. Get in touch!
      </p>
    </div>
  </section>

  <!-- Contact Details -->
  <section class="py-20" style="background-color:#0d0d0d">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12">

        <!-- Left: Info -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Get in Touch</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4 group">
              <div class="w-12 h-12 rounded-full bg-gr8-red/10 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Address</h3>
                <p class="text-gray-400">Pineslopes Office Park, Block C</p>
                <p class="text-gray-400">First Floor, Corner Forest Road & The Straight</p>
                <p class="text-gray-400">Fourways</p>
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div class="w-12 h-12 rounded-full bg-gr8-red/10 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Email</h3>
                <a href="mailto:info@thegr8escape.co.za" class="text-gr8-red hover:text-gr8-gold transition-colors font-medium">info@thegr8escape.co.za</a>
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div class="w-12 h-12 rounded-full bg-gr8-red/10 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <h3 class="text-white font-bold mb-1">Phone</h3>
                <a href="tel:0763620765" class="text-gr8-red hover:text-gr8-gold transition-colors font-medium">076 362 0765</a>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-10">
            <h3 class="text-white font-bold mb-4 uppercase tracking-wider text-xs">Follow Us</h3>
            <div class="flex gap-4">
              <a href="https://www.facebook.com/thegr8escape" target="_blank" rel="noopener noreferrer"
                 class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 hover:scale-110 transition-all">
                <svg class="w-6 h-6 text-gray-400 hover:text-gr8-red" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/thegr8escape" target="_blank" rel="noopener noreferrer"
                 class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 hover:scale-110 transition-all">
                <svg class="w-6 h-6 text-gray-400 hover:text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
              <a href="https://www.tiktok.com/@thegr8escape" target="_blank" rel="noopener noreferrer"
                 class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center hover:bg-gr8-red/20 hover:scale-110 transition-all">
                <svg class="w-6 h-6 text-gray-400 hover:text-gr8-red" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Hours & Refund Policy -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Operating Hours</h2>
          <div class="card-dark p-6 mb-8">
            <table class="w-full text-gray-300">
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Monday</td><td class="py-3 text-right text-gr8-red">Closed</td></tr>
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Tuesday</td><td class="py-3 text-right text-gr8-red">Closed</td></tr>
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Wednesday</td><td class="py-3 text-right text-gr8-red">Closed</td></tr>
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Thursday</td><td class="py-3 text-right text-white">11:00 – 18:00</td></tr>
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Friday</td><td class="py-3 text-right text-white">11:00 – 18:00</td></tr>
              <tr class="border-b border-gray-700"><td class="py-3 font-medium">Saturday</td><td class="py-3 text-right text-white">11:00 – 18:00</td></tr>
              <tr><td class="py-3 font-medium">Sunday</td><td class="py-3 text-right text-white">11:00 – 18:00</td></tr>
            </table>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Refund Policy</h2>
          <div class="card-dark p-6">
            <p class="text-gray-400 mb-3">
              Bookings require a deposit to secure your reservation. The deposit is refundable (less a small admin fee)
              if cancelled at least <strong class="text-white">48 hours</strong> before your scheduled booking.
            </p>
            <p class="text-gray-400 mb-3">
              Cancellations made within 48 hours of the booking time are <strong class="text-gr8-red">non-refundable</strong>.
            </p>
            <p class="text-gray-400">
              Please contact us via email or phone if you need to reschedule or cancel your booking.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .dot-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(229,57,53,0.15) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: dot-pulse 4s ease-in-out infinite;
    opacity: 0.6;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }
</style>
