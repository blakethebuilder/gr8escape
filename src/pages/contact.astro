---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact Us',
  description: 'Get in touch with The Gr8 Escape. Find us in Fourways, Johannesburg.',
};
---

<Layout metadata={metadata}>
  <!-- ════════ HERO ════════ -->
  <section class="contact-hero">
    <div class="contact-hero-bg"></div>
    <div class="contact-hero-content">
      <div class="contact-badge"><span>📬</span> Get in Touch</div>
      <h1>Contact <span class="text-red">Us</span></h1>
      <p>Questions? Ready to book? Just want to say hi? <em>We'd love to hear from you.</em></p>
    </div>
  </section>

  <!-- ════════ INFO CARDS ════════ -->
  <section class="contact-info-section">
    <div class="contact-info-grid">
      <div class="contact-card">
        <div class="cc-icon">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        </div>
        <h3>Find Us</h3>
        <p><strong>Pineslopes Office Park</strong></p>
        <p>Block C, First Floor</p>
        <p>Corner Forest Road & The Straight</p>
        <p class="cc-accent">Fourways, Johannesburg</p>
      </div>

      <div class="contact-card">
        <div class="cc-icon">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
        </div>
        <h3>Email Us</h3>
        <a href="mailto:info@thegr8escape.co.za" class="cc-link">info@thegr8escape.co.za</a>
        <p class="cc-note">We respond within 24 hours</p>
      </div>

      <div class="contact-card">
        <div class="cc-icon">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
        </div>
        <h3>Call Us</h3>
        <a href="tel:0763620765" class="cc-link cc-phone">076 362 0765</a>
        <p class="cc-note">During operating hours</p>
      </div>
    </div>
  </section>

  <!-- ════════ HOURS + REFUND ════════ -->
  <section class="contact-detail-section">
    <div class="contact-detail-grid">
      <div class="detail-card">
        <h2><span>🕐</span> Operating Hours</h2>
        <div class="hours-list">
          <div class="hour-row"><span>Monday</span><span>09:30 – 18:30</span></div>
          <div class="hour-row"><span>Tuesday</span><span>09:30 – 18:30</span></div>
          <div class="hour-row"><span>Wednesday</span><span>09:30 – 18:30</span></div>
          <div class="hour-row"><span>Thursday</span><span>09:30 – 18:30</span></div>
          <div class="hour-row"><span>Friday</span><span>09:30 – 20:00</span></div>
          <div class="hour-row"><span>Saturday</span><span>09:30 – 20:00</span></div>
          <div class="hour-row"><span>Sunday</span><span>09:30 – 18:30</span></div>
        </div>
      </div>

      <div class="detail-card">
        <h2><span>🔄</span> Refund Policy</h2>
        <p>A <strong>R640 deposit</strong> secures your booking (covers 2 tickets). Additional players at <strong>R320/pp</strong> on arrival.</p>
        <p>Cancel or postpone with <strong>24+ hours</strong> notice and <strong>R590</strong> of your R640 deposit is refunded.</p>
        <p>Cancellations within 24 hours are <strong class="text-red">non-refundable</strong>.</p>
        <p class="detail-note">Refunds process within 5–7 days. Request via WhatsApp, email, or phone.</p>
        <a href="/book" class="btn-primary-hero" style="margin:1.5rem auto 0; display:inline-flex;">BOOK YOUR ESCAPE</a>
      </div>
    </div>
  </section>

  <!-- ════════ SOCIAL ════════ -->
  <section class="contact-social-section">
    <h3>Follow the Adventure</h3>
    <div class="social-row">
      <a href="https://www.facebook.com/thegr8escapefourways" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Facebook">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="https://www.instagram.com/gr8escaperooms" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Instagram">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
      <a href="https://www.tiktok.com/@gr8escaperooms" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="TikTok">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  /* ── Hero ── */
  .contact-hero {
    position: relative; padding: 3.5rem 1.5rem 3rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .contact-hero-bg {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(229,57,53,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .contact-hero-content { position: relative; max-width: 34rem; margin: 0 auto; }
  .contact-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red, #E53935);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .contact-hero-content h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 900; color: white;
    line-height: 1.1; margin-bottom: 1rem;
  }
  .contact-hero-content p { font-size: 1.05rem; color: #999; }
  .contact-hero-content em { font-style: normal; color: var(--teal, #06B6D4); font-weight: 600; }

  /* ── Info cards ── */
  .contact-info-section {
    padding: 4rem 1.5rem; background: #0d0d0d;
  }
  .contact-info-grid {
    max-width: 52rem; margin: 0 auto;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .contact-card {
    background: #141414; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1rem; padding: 2rem; text-align: center;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
  }
  .contact-card:hover {
    border-color: rgba(229,57,53,0.25);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.4);
  }
  .cc-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(229,57,53,0.08); color: var(--red, #E53935);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
    transition: all 0.3s;
  }
  .contact-card:hover .cc-icon {
    background: rgba(229,57,53,0.15); transform: scale(1.08);
  }
  .contact-card h3 { font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 0.75rem; }
  .contact-card p { font-size: 0.85rem; color: #999; line-height: 1.6; margin: 0; }
  .contact-card p strong { color: #ddd; }
  .cc-accent { color: var(--teal, #06B6D4) !important; font-weight: 600; margin-top: 0.5rem !important; }
  .cc-link {
    display: block; font-size: 0.95rem; color: var(--red, #E53935); font-weight: 600;
    text-decoration: none; transition: color 0.2s;
  }
  .cc-link:hover { color: var(--teal, #06B6D4); }
  .cc-phone { font-size: 1.3rem; }
  .cc-note { font-size: 0.7rem !important; color: #555 !important; margin-top: 0.5rem !important; }

  /* ── Detail section ── */
  .contact-detail-section {
    padding: 3rem 1.5rem 4rem; background: #0d0d0d;
  }
  .contact-detail-grid {
    max-width: 52rem; margin: 0 auto;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .detail-card {
    background: #141414; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1rem; padding: 2rem;
  }
  .detail-card h2 {
    font-size: 1.25rem; font-weight: 800; color: white;
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .hours-list { display: flex; flex-direction: column; }
  .hour-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.7rem 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 0.85rem; color: #ccc;
  }
  .hour-row:last-child { border-bottom: none; }
  .hour-row.closed span:last-child { color: var(--red, #E53935); font-weight: 600; }
  .detail-card p {
    font-size: 0.85rem; color: #999; line-height: 1.7; margin-bottom: 0.75rem;
  }
  .detail-card p strong { color: #ddd; }
  .detail-note { color: #666 !important; font-size: 0.78rem !important; }

  .btn-primary-hero {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 2rem;
    background: linear-gradient(135deg, #E53935, #B71C1C);
    color: white; font-weight: 700; font-size: 0.9rem;
    text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: 0.6rem; text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    box-shadow: 0 4px 20px rgba(229,57,53,0.3);
    position: relative; overflow: hidden;
  }
  .btn-primary-hero::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
    transform: translateX(-100%); transition: transform 0.5s;
  }
  .btn-primary-hero:hover::after { transform: translateX(100%); }
  .btn-primary-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(229,57,53,0.45); }

  /* ── Social ── */
  .contact-social-section {
    padding: 2.5rem 1.5rem 3.5rem; background: #080808; text-align: center;
  }
  .contact-social-section h3 {
    font-size: 0.75rem; font-weight: 700; color: #666;
    text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
  }
  .social-row { display: flex; justify-content: center; gap: 1rem; }
  .social-btn {
    width: 48px; height: 48px; border-radius: 12px;
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    color: #777; transition: all 0.3s;
  }
  .social-btn:hover {
    background: rgba(229,57,53,0.15); color: var(--red, #E53935);
    transform: translateY(-3px);
  }
</style>
