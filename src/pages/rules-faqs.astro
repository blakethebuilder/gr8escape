---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Rules & FAQs — The Gr8 Escape',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="py-24 bg-[#1a1a1a] text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Rules & FAQs</h1>
      <p class="text-lg text-gray-300">Everything you need to know before your escape room adventure.</p>
    </div>
  </section>

  <!-- Rules -->
  <section class="py-16 bg-[#242424]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-white mb-8">Rules</h2>
      <div class="space-y-4">
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">🔞 Age Requirement</h3>
          <p class="text-gray-300">Players under 16 must be accompanied by an adult. Minimum age is 10 years old.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">📱 No Phones</h3>
          <p class="text-gray-300">No cell phones, cameras, or recording devices are allowed inside the room. This keeps the experience fair for all players.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">🔦 No Excessive Force</h3>
          <p class="text-gray-300">Don't force anything open or use excessive force. Our rooms are designed with clever puzzles — not brute strength.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">⏰ Arrive Early</h3>
          <p class="text-gray-300">Please arrive 15 minutes before your booking. Late arrivals may shorten your game time.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">🏋️ No Food or Drinks</h3>
          <p class="text-gray-300">No food, drinks, or gum are allowed inside the game rooms.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">💡 Ask for Hints</h3>
          <p class="text-gray-300">Stuck? Use the hint system! Our Games Master is watching and ready to help — just ask!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-[#1a1a1a]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-white mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">What happens if I need to cancel?</h3>
          <p class="text-gray-300">Please refer to our refund policy on the Contact page for cancellation and refund details.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">What should I bring?</h3>
          <p class="text-gray-300">Just yourself and your team! Everything you need is provided in the room. Please leave phones and bags outside.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">Can I book a private event?</h3>
          <p class="text-gray-300">Absolutely! We accommodate birthdays, bachelor/bachelorette parties, corporate team building, and more. See our Special Events page for packages.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">What if we don't escape in time?</h3>
          <p class="text-gray-300">Don't worry! The Games Master will let you out. You can always come back and try again!</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">Is the room wheelchair accessible?</h3>
          <p class="text-gray-300">Please contact us to discuss accessibility needs and we'll do our best to accommodate you.</p>
        </div>
        <div class="card-dark p-6">
          <h3 class="text-xl font-bold text-white mb-2">How do I book?</h3>
          <p class="text-gray-300">Book directly through our online booking system. Visit the Bookings page to get started.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
