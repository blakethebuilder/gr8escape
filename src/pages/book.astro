---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Book Your Escape',
  description: 'Book your escape room at The Gr8 Escape. Live availability, room details, and instant booking.',
};

const BOOKING_URL = 'https://gr8bookings.smartintegrate.co.za/book';
const CALENDAR_URL = 'https://gr8bookings.smartintegrate.co.za/availability';

const rooms = [
  { name: 'Asylum Escape', slug: 'asylum-escape', difficulty: '7/10', players: '2–8', duration: '60 min', price: 'R320', icon: '🧪', color: '#E53935' },
  { name: 'Trapped', slug: 'trapped', difficulty: '8/10', players: '2–8', duration: '60 min', price: 'R320', icon: '🔥', color: '#A3E635' },
  { name: 'The Hunted', slug: 'the-hunted', difficulty: '8.5/10', players: '2–8', duration: '60 min', price: 'R320', icon: '🌲', color: '#4CAF50' },
  { name: 'Nightmare', slug: 'nightmare', difficulty: '9/10', players: '2–8', duration: '60 min', price: 'R320', icon: '🌙', color: '#9C27B0' },
  { name: 'The Basement', slug: 'the-basement', difficulty: '10/10', players: '2–8', duration: '60 min', price: 'R320', icon: '⛓️', color: '#FF9800' },
  { name: "The Witch's Curse", slug: 'the-witchs-curse', difficulty: 'Outdoor', players: '2–4', duration: '45 min', price: 'R320', icon: '🧙‍♀️', color: '#7C4DFF' },
];
---

<Layout metadata={metadata}>
  <section class="bk-hero">
    <div class="bk-hero-bg"></div>
    <div class="bk-hero-content">
      <div class="bk-badge"><span>🎟️</span> Book Your Escape</div>
      <h1>Ready to <span class="text-red">Play</span>?</h1>
      <p>Check live availability, pick your room, and lock it in. <em>It only takes a minute.</em></p>
    </div>
  </section>

  <!-- Live Availability -->
  <section class="bk-avail">
    <div class="bk-container">
      <a href={CALENDAR_URL} target="_blank" rel="noopener noreferrer" class="bk-avail-card">
        <div class="bk-avail-left">
          <div class="bk-avail-icon">📅</div>
          <div>
            <h2>Live Availability</h2>
            <p>See open slots across all rooms in real time — always up to date.</p>
          </div>
        </div>
        <div class="bk-avail-arrow">
          <span>Open Calendar</span>
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </div>
      </a>
    </div>
  </section>

  <!-- Room Cards -->
  <section class="bk-rooms">
    <div class="bk-container">
      <h2 class="bk-section-title">Choose Your <span class="text-red">Room</span></h2>
      <div class="bk-room-grid">
        {rooms.map((room) => (
          <a href={`${BOOKING_URL}?room=${room.slug}`} target="_blank" rel="noopener noreferrer" class="bk-room-card" style={`--rc:${room.color}`}>
            <div class="bk-room-top">
              <span class="bk-room-emoji">{room.icon}</span>
              <span class="bk-room-diff" style={`background:${room.color}; color:white`}>{room.difficulty}</span>
            </div>
            <h3>{room.name}</h3>
            <div class="bk-room-stats">
              <span>{room.players}p</span>
              <span>{room.duration}</span>
              <span class="text-lime">{room.price}/pp</span>
            </div>
            <div class="bk-room-btn">Book Now <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bk-cta">
    <h2>Ready to Escape?</h2>
    <div class="bk-cta-buttons">
      <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn-primary-hero glow-red">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        LAUNCH BOOKING SYSTEM
      </a>
      <a href={CALENDAR_URL} target="_blank" rel="noopener noreferrer" class="btn-ghost">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        Live Availability
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  .bk-hero {
    position: relative; padding: 5rem 1.5rem 3rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .bk-hero-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(circle, rgba(229,57,53,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .bk-hero-content { position: relative; max-width: 34rem; margin: 0 auto; }
  .bk-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red, #E53935);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .bk-hero-content h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: white; margin-bottom: 0.75rem; }
  .bk-hero-content p { font-size: 1rem; color: #999; }
  .bk-hero-content em { font-style: normal; color: var(--lime, #A3E635); font-weight: 500; }

  .bk-container { max-width: 48rem; margin: 0 auto; }

  /* Availability card */
  .bk-avail { padding: 0 1.5rem 2rem; background: #080808; }
  .bk-avail-card {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: #111; border: 1px solid rgba(163,230,53,0.15);
    border-radius: 0.85rem; padding: 1.25rem 1.5rem;
    text-decoration: none; transition: all 0.3s;
  }
  .bk-avail-card:hover { border-color: rgba(163,230,53,0.4); transform: translateY(-2px); }
  .bk-avail-left { display: flex; align-items: center; gap: 1rem; }
  .bk-avail-icon { font-size: 2rem; }
  .bk-avail-left h2 { font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 0.2rem; }
  .bk-avail-left p { font-size: 0.8rem; color: #888; }
  .bk-avail-arrow {
    display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0;
    font-size: 0.8rem; font-weight: 600; color: var(--lime, #A3E635);
    transition: gap 0.3s;
  }
  .bk-avail-card:hover .bk-avail-arrow { gap: 0.7rem; }

  /* Room grid */
  .bk-rooms { padding: 2rem 1.5rem 3rem; background: #0d0d0d; }
  .bk-section-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 900; color: white;
    text-align: center; margin-bottom: 1.5rem;
  }
  .bk-room-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.85rem;
  }
  .bk-room-card {
    display: flex; flex-direction: column;
    background: #141414; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.75rem; padding: 1.25rem;
    text-decoration: none;
    transition: all 0.3s;
  }
  .bk-room-card:hover {
    border-color: var(--rc);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.4);
  }
  .bk-room-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .bk-room-emoji { font-size: 2rem; }
  .bk-room-diff {
    padding: 0.15rem 0.5rem; border-radius: 999px;
    font-size: 0.6rem; font-weight: 700;
  }
  .bk-room-card h3 { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
  .bk-room-stats {
    display: flex; gap: 0.6rem; font-size: 0.72rem; color: #888;
    margin-bottom: 1rem;
  }
  .bk-room-btn {
    display: flex; align-items: center; justify-content: center; gap: 0.4rem;
    padding: 0.6rem; border-radius: 0.5rem;
    background: rgba(255,255,255,0.04); color: #ccc;
    font-size: 0.8rem; font-weight: 600;
    transition: all 0.2s; margin-top: auto;
  }
  .bk-room-card:hover .bk-room-btn { background: var(--rc); color: white; }

  /* CTA */
  .bk-cta { padding: 3rem 1.5rem 4rem; background: #080808; text-align: center; }
  .bk-cta h2 { font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 900; color: white; margin-bottom: 1.25rem; }
  .bk-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  .btn-primary-hero {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #E53935, #B71C1C);
    color: white; font-weight: 700; font-size: 0.9rem;
    text-transform: uppercase; letter-spacing: 0.05em;
    border-radius: 0.5rem; text-decoration: none;
    transition: all 0.3s; box-shadow: 0 4px 20px rgba(229,57,53,0.3);
  }
  .btn-primary-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(229,57,53,0.45); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.95rem 1.75rem;
    border: 2px solid rgba(255,255,255,0.12);
    color: white; font-weight: 600; font-size: 0.85rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: all 0.3s;
  }
  .btn-ghost:hover { border-color: var(--lime, #A3E635); background: rgba(163,230,53,0.06); transform: translateY(-2px); }
</style>
