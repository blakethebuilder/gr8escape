---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import LockPuzzle from '~/components/widgets/LockPuzzle.astro';

const metadata = {
  title: 'The Gr8 Escape — SA\'s Highest Rated Escape Room',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center bg-maze-pattern" style="background-color:#0d0d0d">
    <div class="absolute inset-0">
      <img src="/assets/hero-bg.jpg" alt="" class="w-full h-full object-cover opacity-40" style="object-position: center 30%" />
      <div class="absolute inset-0 hero-gradient"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 text-center py-24">
      <img src="/assets/logo-main.png" alt="The Gr8 Escape" class="h-32 md:h-40 mx-auto mb-8" />
      <p class="text-lg md:text-xl text-accent font-bold tracking-wider uppercase mb-4">South Africa's highest rated Escape Room!</p>
      <div class="flex justify-center gap-1 mb-8">
        <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      </div>
      <p class="text-2xl md:text-3xl text-white/80 max-w-3xl mx-auto mb-10">
        Welcome to an immersive puzzle adventure where you and your team have <strong class="text-white">60 minutes</strong> to escape!
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/bookings" class="btn-gr8 text-lg px-10 py-4">BOOK NOW</a>
        <a href="/rooms" class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white rounded-lg font-semibold hover:border-red-500 transition-all">Explore Rooms</a>
      </div>
    </div>
  </section>

  <!-- What is an Escape Room? -->
  <section class="py-20 bg-maze-pattern" style="background-color:#1a1a1a">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">What is an Escape Room?</h2>
      <p class="text-lg text-gray-300 mb-4">
        An escape room is a physical adventure game where a group of <strong class="text-white">2 – 7 players</strong> are given a thrilling scenario to work through.
      </p>
      <p class="text-lg text-gray-300 mb-4">
        Your team will solve a series of puzzles, riddles, and clues to advance through the room and achieve the objective at hand — all under <strong class="text-white">60 minutes!</strong>
      </p>
      <p class="text-xl text-accent font-semibold">With built-in adventure, competition, and suspense!</p>
      <p class="text-2xl text-white font-bold mt-4">You are guaranteed a <span class="text-accent">Gr8 time!</span></p>
    </div>
  </section>

  <!-- Lock Puzzle -->
  <section class="py-20" style="background-color:#242424">
    <LockPuzzle />
  </section>

  <!-- 3 Feature Cards: Fun Night Out, Special Events, Team Building -->
  <section class="py-20" style="background-color:#242424">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-md mx-auto">
        <!-- Fun Night Out -->
        <div class="card-dark text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Fun Night Out</h3>
          <p class="text-gray-400 mb-4">
            Are you spending every night watching the same movies? Switch it up with a fun night out at the Escape Room.
          </p>
          <p class="text-gray-400">
            Grab your smartest friends and family and see if you have what it takes to <strong class="text-white">escape the room.</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Special Events & Team Building -->
  <section class="py-20" style="background-color:#1a1a1a">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card-dark text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Special Events</h3>
          <p class="text-gray-400 mb-4">Birthday parties, bachelor/bachelorette, or just fun with friends — we have packages to make it special.</p>
          <div class="space-y-2 text-left max-w-xs mx-auto">
            <p class="text-gray-400 text-sm flex justify-between"><span>Birthday Package</span><span class="text-white font-bold">R500</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Challenge Wheel</span><span class="text-white font-bold">R50</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Bachelor's Package</span><span class="text-white font-bold">R550/pp</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Bachelorette's Package</span><span class="text-white font-bold">R450/pp</span></p>
          </div>
        </div>
        <div class="card-dark text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Team Building</h3>
          <p class="text-gray-400 mb-2">Don't spend another team building day doing trust falls.</p>
          <p class="text-gray-400">The Escape Room provides the ultimate team building activity because everyone shares the same goal — <strong class="text-white">to escape the room.</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20" style="background-color:#1a1a1a; background-image:url(/assets/bg-pattern.png)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Do you have what it takes to Escape?</h2>
      <p class="text-xl text-gray-300 mb-8">
        Book now to experience immersive storytelling, mind bending challenges, and collaborative puzzle solving in each of our unique Escape Rooms!
      </p>
      <a href="/bookings" class="btn-gr8 text-lg px-10 py-4">BOOK NOW</a>
    </div>
  </section>
</Layout>
