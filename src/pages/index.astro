---
import Layout from '~/layouts/PageLayout.astro';
import LockPuzzle from '~/components/widgets/LockPuzzle.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import ParticleBackground from '~/components/common/ParticleBackground.astro';

const metadata = {
  title: "The Gr8 Escape — SA's Highest Rated Escape Room",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- ════════════ HERO ════════════ -->
  <section class="hero-section">
    <ParticleBackground particleCount={150} connectDistance={180} speed={0.5} opacity={0.9} />
    <div class="hero-vignette"></div>
    <div class="hero-scanlines"></div>

    <div class="hero-content">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        Fourways, Johannesburg
      </div>

      <p class="hero-tagline">South Africa's Highest Rated Escape Room</p>

      <h1 class="hero-title-block">
        <span class="hero-word">The</span>
        <span class="hero-word hero-accent">Gr8</span>
        <span class="hero-word">Escape</span>
      </h1>

      <!-- Timer -->
      <div class="timer-block">
        <svg viewBox="0 0 140 140" class="timer-svg">
          <defs>
            <filter id="timer-glow">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <circle cx="70" cy="70" r="60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
          <circle cx="70" cy="70" r="60" fill="none" stroke="#E53935" stroke-width="5"
            stroke-linecap="round" stroke-dasharray="377" class="timer-arc" filter="url(#timer-glow)"/>
          <text x="70" y="64" text-anchor="middle" fill="white" font-size="32" font-weight="900" font-family="'Courier New',monospace" letter-spacing="2">60:00</text>
          <text x="70" y="86" text-anchor="middle" fill="#888" font-size="11" font-weight="700" letter-spacing="4">MINUTES</text>
        </svg>
      </div>

      <p class="hero-subtitle">
        You and your team have <strong>60 minutes</strong> to crack codes, solve puzzles, and find your way out.
        <em>Can you beat the clock?</em>
      </p>

      <div class="hero-actions">
        <a href="/book" class="btn-primary-hero">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          BOOK NOW
        </a>
        <a href="/rooms" class="btn-ghost-hero">
          Explore Rooms
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

      <div class="scroll-hint">
        <span>Scroll to discover</span>
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </div>
    </div>
  </section>

  <!-- ════════════ SECTION DIVIDER ════════════ -->
  <div class="section-divider"></div>

  <!-- ════════════ EXPERIENCE EXPLAINER ════════════ -->
  <section class="experience-section">
    <div class="exp-bg-pattern"></div>
    <div class="exp-container">
      <div class="exp-label"><span>🎯</span> The Experience</div>
      <h2 class="exp-heading">What is an <span class="text-red">Escape Room</span>?</h2>

      <div class="exp-description">
        <p>A live-action adventure where <strong>your team of 2–8</strong> steps into a themed room with one goal: <strong>escape before the clock hits zero.</strong></p>
        <p>No phones. No distractions. Just you, your crew, and a series of interconnected puzzles standing between you and freedom.</p>
      </div>

      <div class="stat-tiles">
        <div class="stat-tile">
          <span class="stat-icon">🧩</span>
          <span class="stat-value">2–8</span>
          <span class="stat-label">Players</span>
        </div>
        <div class="stat-tile">
          <span class="stat-icon">⏱️</span>
          <span class="stat-value">60</span>
          <span class="stat-label">Minutes</span>
        </div>
        <div class="stat-tile">
          <span class="stat-icon">⭐</span>
          <span class="stat-value">5.0</span>
          <span class="stat-label">Google Rating</span>
        </div>
      </div>

      <p class="exp-tagline">Adventure. Suspense. Pure adrenaline.</p>
      <p class="exp-closer">You're guaranteed a <span class="text-teal">Gr8 time!</span></p>
    </div>
  </section>

  <!-- ════════════ LOCK PUZZLE ════════════ -->
  <section class="puzzle-section">
    <div class="puzzle-bg"></div>
    <LockPuzzle />
  </section>

  <!-- ════════════ TESTIMONIALS ════════════ -->
  <Testimonials />

  <!-- ════════════ WHY CHOOSE US ════════════ -->
  <section class="features-section">
    <div class="features-bg"></div>
    <div class="features-container">
      <div class="features-label"><span>🔥</span> Why Choose Us</div>
      <h2 class="features-heading">More Than Just <span class="text-red">a Game</span></h2>

      <div class="features-grid">
        <article class="feature-card">
          <div class="feature-glow"></div>
          <div class="feature-icon">
            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z"/></svg>
          </div>
          <h3>Bring Your Crew</h3>
          <p>Same restaurant, same conversation, same boring night out? <strong>Not tonight.</strong> Grab your sharpest friends and step into a live puzzle.</p>
          <span class="feature-tag">Most Popular</span>
        </article>

        <article class="feature-card">
          <div class="feature-glow"></div>
          <div class="feature-icon">
            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 3v18"/></svg>
          </div>
          <h3>Make It Legendary</h3>
          <p>Birthdays, bachelor parties, team outings — we turn gatherings into <strong>stories you'll retell for years.</strong></p>
          <div class="feature-prices">
            <span>Birthday <strong>R500</strong></span>
            <span>Bachelor's <strong>R450/pp</strong></span>
            <span>Bachelorette's <strong>R450/pp</strong></span>
          </div>
        </article>

        <article class="feature-card">
          <div class="feature-glow"></div>
          <div class="feature-icon">
            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 012 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <h3>Forge Your Team</h3>
          <p>Trust falls? Icebreakers? <strong>Hard pass.</strong> Nothing builds real camaraderie like shared panic — and shared triumph.</p>
          <span class="feature-tag feature-tag-teal">Corporate Ready</span>
        </article>
      </div>
    </div>
  </section>

  <!-- ════════════ FINAL CTA ════════════ -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="cta-content">
      <h2>Do You Have What It Takes to <span class="text-red">Escape</span>?</h2>
      <p>Immersive worlds. Mind-bending puzzles. <strong>60 minutes.</strong> The only question left is — <em>will you make it out?</em></p>
      <a href="/book" class="btn-primary-hero glow-red">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        BOOK YOUR ESCAPE
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  /* ── Color tokens ── */
  :root {
    --red: #E53935;
    --red-dark: #B71C1C;
    --teal: #06B6D4;
    --teal-dark: #0891B2;
    --bg-deep: #080808;
    --bg-dark: #0d0d0d;
    --bg-mid: #141414;
    --bg-card: #1a1a1a;
    --border-dim: rgba(255,255,255,0.06);
    --border-mid: rgba(255,255,255,0.1);
  }

  /* ── Shared utility helpers ── */
  .text-red { color: var(--red); }
  .text-teal { color: var(--teal); }

  /* ════════════ HERO ════════════ */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080808;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle, rgba(229,57,53,0.06) 1px, transparent 1px);
    background-size: 52px 52px;
    animation: bg-drift 20s linear infinite;
  }
  @keyframes bg-drift {
    0% { background-position: 0 0; }
    100% { background-position: 52px 52px; }
  }
  .hero-vignette {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 40%, transparent 20%, var(--bg-deep) 75%);
    pointer-events: none;
  }
  .hero-scanlines {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none; opacity: 0.5;
  }
  .hero-content {
    position: relative; z-index: 1;
    text-align: center;
    padding: 4rem 1.5rem;
    max-width: 56rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    color: #999; font-size: 0.8rem; font-weight: 500;
    margin-bottom: 2rem;
    animation: fade-up 0.6s ease-out 0.1s both;
  }
  .pulse-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--teal);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.3); }
  }

  /* Tagline */
  .hero-tagline {
    font-size: 0.8rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.35em;
    color: var(--teal);
    margin-bottom: 1.5rem;
    animation: fade-up 0.6s ease-out 0.2s both;
  }

  /* Title */
  .hero-title-block {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 0.5rem 1.5rem;
    margin-bottom: 2.5rem;
    animation: fade-up 0.6s ease-out 0.35s both;
  }
  .hero-word {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    color: white;
    line-height: 1;
    letter-spacing: -0.02em;
    transition: color 0.4s;
  }
  .hero-word:hover { color: var(--teal); }
  .hero-accent {
    color: var(--red);
    text-shadow: 0 0 60px rgba(229,57,53,0.5), 0 0 120px rgba(229,57,53,0.2);
  }
  .hero-accent:hover { color: var(--red); text-shadow: 0 0 80px rgba(229,57,53,0.7); }

  /* Timer */
  .timer-block {
    display: flex; justify-content: center;
    margin-bottom: 2rem;
    animation: fade-up 0.6s ease-out 0.5s both;
  }
  .timer-svg {
    width: 130px; height: 130px;
    filter: drop-shadow(0 0 15px rgba(229,57,53,0.3));
  }
  .timer-arc {
    animation: timer-drain 60s linear infinite;
    transform-origin: center; transform: rotate(-90deg);
  }
  @keyframes timer-drain {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 377; }
  }

  /* Subtitle */
  .hero-subtitle {
    max-width: 36rem; margin: 0 auto 2.5rem;
    font-size: 1.15rem; line-height: 1.7;
    color: #aaa;
    animation: fade-up 0.6s ease-out 0.65s both;
  }
  .hero-subtitle strong { color: white; font-weight: 600; }
  .hero-subtitle em { display: block; margin-top: 0.75rem; font-style: normal; color: var(--teal); font-weight: 600; }

  /* Buttons */
  .hero-actions {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;
    animation: fade-up 0.6s ease-out 0.8s both;
  }
  .btn-primary-hero {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.25rem;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white; font-weight: 700; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: 0.6rem;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    box-shadow: 0 4px 20px rgba(229,57,53,0.3);
    position: relative; overflow: hidden;
  }
  .btn-primary-hero::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
    transform: translateX(-100%); transition: transform 0.5s;
  }
  .btn-primary-hero:hover::after { transform: translateX(100%); }
  .btn-primary-hero:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(229,57,53,0.45);
  }
  .btn-primary-hero:active { transform: translateY(0); }

  .btn-ghost-hero {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 1rem 2rem;
    border: 2px solid rgba(255,255,255,0.12);
    color: white; font-weight: 600; font-size: 0.9rem;
    border-radius: 0.6rem;
    transition: all 0.3s;
  }
  .btn-ghost-hero:hover {
    border-color: var(--red);
    background: rgba(229,57,53,0.08);
    transform: translateY(-2px);
  }

  /* Scroll hint */
  .scroll-hint {
    margin-top: 4rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: #555; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em;
    animation: fade-up 0.6s ease-out 1s both, bob 2s ease-in-out 1.5s infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ════════════ EXPERIENCE ════════════ */
  .experience-section {
    position: relative;
    padding: 4rem 1.5rem;
    background: var(--bg-mid);
    overflow: hidden;
  }
  .exp-bg-pattern {
    position: absolute; inset: 0; opacity: 0.15;
    background-image: radial-gradient(circle, rgba(6,182,212,0.15) 1px, transparent 1px);
    background-size: 36px 36px;
  }
  .exp-container {
    position: relative; max-width: 42rem; margin: 0 auto; text-align: center;
  }
  .exp-label {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .exp-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 900; color: white;
    line-height: 1.15; margin-bottom: 2rem;
  }
  .exp-description {
    max-width: 34rem; margin: 0 auto 3rem;
    font-size: 1.1rem; line-height: 1.8; color: #bbb;
  }
  .exp-description strong { color: white; font-weight: 600; }

  .stat-tiles {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem; max-width: 22rem; margin: 0 auto 2.5rem;
  }
  .stat-tile {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 1rem;
    padding: 1.25rem 0.75rem;
    transition: all 0.3s;
    display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
  }
  .stat-tile:hover {
    border-color: var(--red);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(229,57,53,0.1);
  }
  .stat-icon { font-size: 1.8rem; }
  .stat-value { font-size: 1.4rem; font-weight: 800; color: white; }
  .stat-label { font-size: 0.65rem; color: #666; text-transform: uppercase; letter-spacing: 0.1em; }

  .exp-tagline {
    font-size: 1.15rem; color: var(--teal); font-weight: 600; margin-bottom: 0.5rem;
  }
  .exp-closer {
    font-size: 1.5rem; color: white; font-weight: 800;
  }

  /* ════════════ PUZZLE ════════════ */
  .puzzle-section {
    position: relative;
    padding: 5rem 0;
    background: #1a1a1a;
    overflow: hidden;
  }
  .puzzle-bg {
    position: absolute; inset: 0; opacity: 0.12;
    background-image: radial-gradient(circle, rgba(229,57,53,0.12) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  /* ════════════ FEATURES ════════════ */
  .features-section {
    position: relative;
    padding: 4rem 1.5rem;
    background: var(--bg-dark);
    overflow: hidden;
  }
  .features-bg {
    position: absolute; inset: 0; opacity: 0.4;
  }
  .features-container {
    position: relative; max-width: 64rem; margin: 0 auto; text-align: center;
  }
  .features-label {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }
  .features-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 900; color: white;
    line-height: 1.15; margin-bottom: 3rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 1rem;
    padding: 2rem;
    text-align: center;
    transition: all 0.35s cubic-bezier(0.22,1,0.36,1);
    overflow: hidden;
  }
  .feature-glow {
    position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
    background: radial-gradient(circle at center, rgba(229,57,53,0.06) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.4s;
    pointer-events: none;
  }
  .feature-card:hover .feature-glow { opacity: 1; }
  .feature-card:hover {
    border-color: rgba(229,57,53,0.3);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(229,57,53,0.1);
  }
  .feature-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(229,57,53,0.08);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
    color: var(--red);
    transition: all 0.3s;
  }
  .feature-card:hover .feature-icon {
    background: rgba(229,57,53,0.15);
    transform: scale(1.08);
    box-shadow: 0 0 25px rgba(229,57,53,0.2);
  }
  .feature-card h3 {
    font-size: 1.35rem; font-weight: 800; color: white;
    margin-bottom: 0.75rem;
    transition: color 0.3s;
  }
  .feature-card:hover h3 { color: var(--red); }
  .feature-card p {
    color: #999; font-size: 0.9rem; line-height: 1.65;
  }
  .feature-card p strong { color: #ddd; }

  .feature-prices {
    display: flex; flex-direction: column; gap: 0.4rem;
    margin-top: 1.25rem; padding-top: 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 0.8rem; color: #888;
  }
  .feature-prices span {
    display: flex; justify-content: space-between;
  }
  .feature-prices strong { color: white; }

  .feature-tag {
    display: inline-block; margin-top: 1rem;
    padding: 0.25rem 0.75rem; border-radius: 999px;
    background: rgba(229,57,53,0.1); color: var(--red);
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .feature-tag-teal {
    background: rgba(6,182,212,0.1); color: var(--teal);
  }

  /* ════════════ FINAL CTA ════════════ */
  .cta-section {
    position: relative;
    padding: 4rem 1.5rem;
    background: var(--bg-deep);
    overflow: hidden;
  }
  .cta-bg {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle, rgba(229,57,53,0.08) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .cta-content {
    position: relative; max-width: 36rem; margin: 0 auto; text-align: center;
  }
  .cta-content h2 {
    font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 900; color: white;
    line-height: 1.2; margin-bottom: 1.25rem;
  }
  .cta-content p {
    font-size: 1.05rem; color: #999; line-height: 1.7; margin-bottom: 2rem;
  }
  .cta-content strong { color: white; }
