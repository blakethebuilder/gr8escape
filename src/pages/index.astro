---
import Layout from '~/layouts/PageLayout.astro';

import CallToAction from '~/components/widgets/CallToAction.astro';
import LockPuzzle from '~/components/widgets/LockPuzzle.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'The Gr8 Escape — SA\'s Highest Rated Escape Room',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero — full rebuild: energetic, immersive, fun -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background:#0a0a0a">
    <!-- Animated dot grid background -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="dot-grid"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 0%, #0a0a0a 70%)"></div>
    </div>

    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 py-24">
      <div class="text-center">
        <!-- Tagline reveal -->
        <p class="tagline-reveal text-gr8-gold font-bold tracking-[0.3em] uppercase text-sm md:text-base mb-6">
          South Africa's Highest Rated Escape Room
        </p>

        <!-- Main heading: staggered letter animation -->
        <h1 class="hero-title mb-6">
          <span class="sr-only">The Gr8 Escape</span>
          <span class="hero-line" aria-hidden="true">
            <span class="letter" style="animation-delay:0.0s">T</span>
            <span class="letter" style="animation-delay:0.05s">h</span>
            <span class="letter" style="animation-delay:0.1s">e</span>
            <span class="letter-spacer" aria-hidden="true"> </span>
            <span class="letter" style="animation-delay:0.15s">G</span>
            <span class="letter letter-gr8" style="animation-delay:0.2s; color:#E53935">R</span>
            <span class="letter" style="animation-delay:0.25s">8</span>
            <span class="letter-spacer" aria-hidden="true"> </span>
            <span class="letter" style="animation-delay:0.3s">E</span>
            <span class="letter" style="animation-delay:0.35s">s</span>
            <span class="letter" style="animation-delay:0.4s">c</span>
            <span class="letter" style="animation-delay:0.45s">a</span>
            <span class="letter" style="animation-delay:0.5s">p</span>
            <span class="letter" style="animation-delay:0.55s">e</span>
          </span>
        </h1>

        <!-- 60-minute countdown ring -->
        <div class="flex justify-center mb-8">
          <div class="timer-ring">
            <svg viewBox="0 0 120 120" class="w-28 h-28 md:w-32 md:h-32">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#222" stroke-width="4" />
              <circle cx="60" cy="60" r="52" fill="none" stroke="#E53935" stroke-width="4"
                stroke-linecap="round" stroke-dasharray="326.7"
                class="timer-arc" />
              <text x="60" y="55" text-anchor="middle" fill="white" font-size="28" font-weight="800" font-family="'Courier New',monospace">60:00</text>
              <text x="60" y="78" text-anchor="middle" fill="#aaa" font-size="10" font-weight="600">MINUTES</text>
            </svg>
          </div>
        </div>

        <p class="hero-desc text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10">
          You and your team have <strong class="text-white">60 minutes</strong> to solve puzzles, find clues, and break free.
          <span class="block text-gr8-gold font-semibold mt-2">Can you beat the clock?</span>
        </p>

        <div class="flex flex-wrap justify-center gap-4 hero-cta">
          <a href="/bookings" class="btn-gr8 text-lg px-10 py-4 shadow-lg shadow-red-500/25">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              BOOK NOW
            </span>
          </a>
          <a href="/rooms" class="hero-outline-btn">
            Explore Rooms
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>

        <!-- Scroll indicator -->
        <div class="mt-16 animate-bounce">
          <svg class="w-6 h-6 mx-auto text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- What is an Escape Room? — with visual punch -->
  <section class="py-20 relative overflow-hidden" style="background-color:#1a1a1a">
    <div class="absolute inset-0 opacity-20" style="background-image:radial-gradient(circle,rgba(229,57,53,0.08) 1px,transparent 1px);background-size:32px 32px"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-red-500/10 text-gr8-red text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-6">
        <span>🎯</span> The Experience
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">What is an <span class="text-gr8-red">Escape Room</span>?</h2>
      <div class="max-w-3xl mx-auto space-y-4 text-lg text-gray-300 leading-relaxed">
        <p>
          An escape room is a physical adventure game where a group of <strong class="text-white">2–7 players</strong> are locked in a themed room and given a thrilling scenario to work through.
        </p>
        <p>
          Your team must solve a series of puzzles, riddles, and clues to advance through the room and complete the objective — all under <strong class="text-white">60 minutes!</strong>
        </p>
      </div>
      <div class="mt-8 grid grid-cols-3 gap-4 max-w-lg mx-auto">
        <div class="bg-[#242424] rounded-xl p-4 border border-white/5">
          <div class="text-3xl mb-1">🧩</div>
          <div class="text-white font-bold text-lg">2–7</div>
          <div class="text-gray-500 text-xs">Players</div>
        </div>
        <div class="bg-[#242424] rounded-xl p-4 border border-white/5">
          <div class="text-3xl mb-1">⏱️</div>
          <div class="text-white font-bold text-lg">60</div>
          <div class="text-gray-500 text-xs">Minutes</div>
        </div>
        <div class="bg-[#242424] rounded-xl p-4 border border-white/5">
          <div class="text-3xl mb-1">🏆</div>
          <div class="text-white font-bold text-lg">5★</div>
          <div class="text-gray-500 text-xs">Rating</div>
        </div>
      </div>
      <p class="text-xl text-gr8-gold font-semibold mt-8">With built-in adventure, competition, and suspense!</p>
      <p class="text-2xl text-white font-bold mt-2">You are guaranteed a <span class="text-gr8-gold">Gr8 time!</span> 🎉</p>
    </div>
  </section>

  <!-- Lock Puzzle -->
  <section class="py-20 relative overflow-hidden" style="background-color:#242424">
    <div class="absolute inset-0 opacity-20" style="background-image:radial-gradient(circle,rgba(229,57,53,0.08) 1px,transparent 1px);background-size:32px 32px"></div>
    <div class="relative">
      <LockPuzzle />
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Feature Cards: Fun Night Out, Special Events, Team Building -->
  <section class="py-20 relative overflow-hidden" style="background-color:#0d0d0d">
    <div class="absolute inset-0 dot-grid opacity-30"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-red-500/10 text-gr8-red text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4">
          <span>🔥</span> Why Choose Us
        </div>
        <h2 class="text-3xl md:text-5xl font-bold text-white">More Than Just <span class="text-gr8-red">a Game</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Fun Night Out -->
        <div class="group card-dark text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gr8-red to-gr8-gold opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-gr8-red transition-colors">Bring Your Crew</h3>
          <p class="text-gray-400 mb-3">
            Same restaurant, same conversation, same boring night out? <strong class="text-white">Not tonight.</strong>
          </p>
          <p class="text-gray-400 text-sm">
            Grab your sharpest friends, step into a live puzzle, and find out who really pays attention. Winner buys the next round.
          </p>
        </div>

        <!-- Special Events -->
        <div class="group card-dark text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gr8-gold to-gr8-red opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-gr8-red transition-colors">Make It Legendary</h3>
          <p class="text-gray-400 mb-4">
            Birthdays, bachelor parties, or just an excuse to get together — we make it actually memorable.
          </p>
          <div class="space-y-2 text-left max-w-xs mx-auto">
            <p class="text-gray-400 text-sm flex justify-between"><span>Birthday Package</span><span class="text-white font-bold">R500</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Challenge Wheel</span><span class="text-white font-bold">R50</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Bachelor's</span><span class="text-white font-bold">R550/pp</span></p>
            <p class="text-gray-400 text-sm flex justify-between"><span>Bachelorette's</span><span class="text-white font-bold">R450/pp</span></p>
          </div>
        </div>

        <!-- Team Building -->
        <div class="group card-dark text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gr8-red to-gr8-gold opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8 text-gr8-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 012 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-gr8-red transition-colors">Forge Your Team</h3>
          <p class="text-gray-400 mb-2">Trust falls? Icebreakers? <strong class="text-white">Hard pass.</strong></p>
          <p class="text-gray-400 text-sm">The only team activity where everyone actually works together under pressure. Shared panic, shared triumph — that's a real team.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 relative overflow-hidden" style="background-color:#0d0d0d">
    <div class="absolute inset-0">
      <div class="dot-grid"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 0%, #0d0d0d 70%)"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">Do You Have What It Takes to <span class="text-gr8-red">Escape</span>?</h2>
      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Immersive storytelling, mind bending challenges, and collaborative puzzle solving await. The clock is ticking.
      </p>
      <a href="/bookings" class="btn-gr8 text-lg px-12 py-4 shadow-lg shadow-red-500/30 inline-flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        BOOK YOUR ESCAPE
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  /* ── Dot grid background ── */
  .dot-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(229,57,53,0.15) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: dot-pulse 4s ease-in-out infinite;
    opacity: 0.6;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }

  /* ── Hero title stagger animation ── */
  .hero-title {
    display: block;
  }
  .hero-line {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
  }
  .letter {
    display: inline-block;
    font-size: clamp(3rem, 12vw, 7rem);
    font-weight: 900;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.1;
    opacity: 0;
    transform: translateY(40px) rotateX(-20deg);
    animation: letter-rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .letter-spacer {
    display: inline-block;
    width: 0.3em;
  }
  .letter-gr8 {
    color: #E53935;
    text-shadow: 0 0 30px rgba(229,57,53,0.4);
  }
  @keyframes letter-rise {
    to {
      opacity: 1;
      transform: translateY(0) rotateX(0);
    }
  }

  /* ── Tagline reveal ── */
  .tagline-reveal {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 0.3s forwards;
  }
  @keyframes fade-slide-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Timer ring ── */
  .timer-ring {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 0.8s forwards;
  }
  .timer-arc {
    animation: timer-drain 60s linear infinite;
    transform-origin: center;
    transform: rotate(-90deg);
  }
  @keyframes timer-drain {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 326.7; }
  }
  .timer-ring:hover .timer-arc {
    animation-duration: 30s;
    stroke: #FFB900;
    transition: stroke 0.3s;
  }

  /* ── Hero description ── */
  .hero-desc {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 1.1s forwards;
  }
  .hero-cta {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 1.4s forwards;
  }

  /* ── Outline button ── */
  .hero-outline-btn {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    border: 2px solid rgba(255,255,255,0.2);
    color: white;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: all 0.3s;
  }
  .hero-outline-btn:hover {
    border-color: #E53935;
    background: rgba(229,57,53,0.1);
    transform: translateY(-2px);
  }
</style>
