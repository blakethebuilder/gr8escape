---
import Layout from '~/layouts/PageLayout.astro';

const rooms = [
  { name: 'Asylum Escape', difficulty: '7/10', img: '/assets/asylum.jpg', icon: '🧪',
    story: 'You and your team have been sent to investigate the office of Dr. Mulasy Tretour. You have 60 minutes to find a way out before they get hold of you.' },
  { name: 'Trapped', difficulty: '8/10', img: '/assets/trapped.jpg', icon: '🔥',
    story: 'Welcomed by a Butler at a wealthy gold trader\'s home, a fire breaks out. 60 minutes to escape before you are burned alive!' },
  { name: 'The Hunted', difficulty: '8.5/10', img: '/assets/hunted.jpg', icon: '🌲',
    story: 'You journey to your uncle\'s abandoned cabin. The door slams shut. Can YOU escape the creature the town has fallen to?' },
  { name: 'Nightmare', difficulty: '9/10', img: '/assets/nightmare.jpg', icon: '🌙',
    story: 'The Sandman comes out on the night of the Dead Moon. 60 minutes before he claims you as one of his night terrors forever.' },
  { name: 'The Basement', difficulty: '10/10', img: '/assets/basement.jpg', icon: '⛓️',
    story: 'Waking up in a dark basement, chains dragging. You are pawns in a psychopath\'s game — can you make it out?' },
];
---

<Layout metadata={{ title: 'Our Rooms — The Gr8 Escape' }}>
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center overflow-hidden" style="background:#0d0d0d">
    <div class="absolute inset-0 overflow-hidden">
      <div class="dot-grid"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 0%, #0d0d0d 70%)"></div>
    </div>
    <div class="relative w-full max-w-5xl mx-auto px-4 sm:px-6 py-24 text-center">
      <p class="tagline-reveal text-gr8-gold font-bold tracking-[0.3em] uppercase text-sm md:text-base mb-6">Choose Your Challenge</p>
      <h1 class="hero-heading text-5xl md:text-7xl font-black text-white mb-4">Our Escape Rooms</h1>
      <p class="hero-sub text-lg md:text-xl text-gray-300 max-w-xl mx-auto">5 unique rooms + a special outdoor experience.<br><span class="text-gr8-red font-semibold">Can you escape them all?</span></p>
    </div>
  </section>

  <!-- Room Cards -->
  <section class="py-20" style="background-color:#0d0d0d">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rooms.map(r => (
          <div class="room-card group">
            <div class="room-card-img h-56 bg-cover bg-center relative" style={`background-image:url(${r.img})`}>
              <div class="absolute inset-0 bg-gradient-to-t from-[#1e1e1e] via-[#1e1e1e]/30 to-transparent"></div>
              <span class="absolute bottom-3 left-3 text-5xl">{r.icon}</span>
              <span class="absolute top-3 right-3 difficulty-badge">{r.difficulty}</span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <h2 class="text-xl font-bold text-white mb-3">{r.name}</h2>
              <p class="text-gray-400 text-sm leading-relaxed mb-5 flex-1">{r.story}</p>
              <a href="https://thegr8escape.co.za/bookings/" target="_blank" class="btn-gr8 w-full text-center text-sm py-3">BOOK NOW</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Witch's Curse Featured -->
  <section class="py-20" style="background-color:#0d0d0d">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="featured-card overflow-hidden md:flex">
        <div class="md:w-1/3 h-64 md:h-auto bg-gradient-to-br from-purple-900/60 to-[#1a1a1a] flex items-center justify-center relative">
          <div class="absolute inset-0 dot-grid-subtle opacity-30"></div>
          <span class="text-7xl relative z-10">🧙‍♀️</span>
        </div>
        <div class="md:w-2/3 p-8">
          <span class="text-xs font-bold text-gr8-red bg-gr8-red/10 px-3 py-1.5 rounded-full mb-4 inline-block tracking-wider uppercase">Outdoor Experience</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">The Witch's Curse</h2>
          <p class="text-gray-300 mb-4">Hidden within a container at <strong class="text-white">The Golf Place — Fore-Ways</strong> lies a curse waiting to be broken. Solve magical puzzles in just <strong class="text-white">45 minutes</strong>.</p>
          <div class="grid grid-cols-3 gap-4 text-center mb-6 max-w-sm">
            <div class="bg-[#242424] rounded-lg p-3 border border-gray-700/50"><span class="text-gr8-red font-bold block text-lg">2–4</span><span class="text-xs text-gray-400">Players</span></div>
            <div class="bg-[#242424] rounded-lg p-3 border border-gray-700/50"><span class="text-gr8-red font-bold block text-lg">45 min</span><span class="text-xs text-gray-400">Duration</span></div>
            <div class="bg-[#242424] rounded-lg p-3 border border-gray-700/50"><span class="text-gr8-red font-bold block text-lg">R320</span><span class="text-xs text-gray-400">Per person</span></div>
          </div>
          <a href="https://thegr8escape.co.za/bookings/" target="_blank" class="btn-gr8 inline-block">BOOK THIS ROOM</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* ── Dot grid ── */
  .dot-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(229,57,53,0.15) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: dot-pulse 4s ease-in-out infinite;
    opacity: 0.6;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }
  .dot-grid-subtle {
    background-image: radial-gradient(circle, rgba(229,57,53,0.12) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  /* ── Hero ── */
  .hero-heading {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 0.3s forwards;
  }
  .hero-sub {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 0.6s forwards;
  }
  .tagline-reveal {
    opacity: 0;
    animation: fade-slide-up 0.8s ease-out 0.1s forwards;
  }
  @keyframes fade-slide-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Room card ── */
  .room-card {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 0.75rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    position: relative;
  }
  .room-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: #E53935;
    z-index: 2;
  }
  .room-card:hover {
    border-color: #E53935;
    transform: translateY(-6px);
    box-shadow: 0 12px 35px rgba(229,57,53,0.2);
  }
  .room-card-img {
    position: relative;
  }
  .difficulty-badge {
    display: inline-flex;
    align-items: center;
    background: linear-gradient(135deg, #E53935, #C62828);
    color: white;
    font-weight: 800;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
    box-shadow: 0 2px 10px rgba(229,57,53,0.4);
  }

  /* ── Featured card (Witch's Curse) ── */
  .featured-card {
    background: #1e1e1e;
    border-radius: 0.75rem;
    position: relative;
    border: 1px solid rgba(156,39,176,0.3);
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
  }
  .featured-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 0.85rem;
    padding: 1px;
    background: linear-gradient(135deg, rgba(156,39,176,0.5), rgba(255,185,0,0.3), rgba(156,39,176,0.5));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(156,39,176,0.2);
  }
</style>
