---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Our Rooms',
  description: 'Explore all 6 escape rooms at The Gr8 Escape. From Asylum to The Basement — which will you conquer?',
};

const rooms = [
  {
    name: 'Asylum Escape', difficulty: 7, icon: '🧪', color: '#E53935',
    players: '2–8', duration: '60 min', price: 'R250',
    story: "Dr. Mulasy Tretour's office holds evidence of his vicious crimes — but one of his experiments is closer than you think. Gather the proof and get out before they get hold of you.",
    tag: 'Most Popular',
  },
  {
    name: 'Trapped', difficulty: 8, icon: '🔥', color: '#06B6D4',
    players: '2–8', duration: '60 min', price: 'R250',
    story: "The Butler welcomes you to Mr. Charles A Clarence's estate. Then the smoke starts pouring in. A fire is tearing through the mansion — find another way out before you're burned alive.",
  },
  {
    name: 'The Hunted', difficulty: 8.5, icon: '🌲', color: '#4CAF50',
    players: '2–8', duration: '60 min', price: 'R250',
    story: "Your uncle went quiet after months of letters from Eldertree. At his abandoned cabin the door slams shut. Movement in the woods. Can you escape the creature that's taken the town?",
  },
  {
    name: 'Nightmare', difficulty: 9, icon: '🌙', color: '#9C27B0',
    players: '2–8', duration: '60 min', price: 'R250',
    story: "The Dead Moon rises once a year. Tonight the Sandman walks among us. You have 60 minutes to break his curse — or join his collection of night terrors forever.",
  },
  {
    name: 'The Basement', difficulty: 10, icon: '⛓️', color: '#FF9800',
    players: '2–8', duration: '60 min', price: 'R250',
    story: "You wake up in darkness. Chains dragging on metal. You're pawns in a psychopath's game — 60 minutes to escape his chamber for good. Our hardest room.",
    tag: 'Hardest',
  },
  {
    name: "The Witch's Curse", difficulty: 'Outdoor', icon: '🧙‍♀️', color: '#7C4DFF',
    players: '2–4', duration: '45 min', price: 'R320',
    story: "Hidden within a container at The Golf Place — Fore-Ways lies a curse waiting to be broken. Solve magical puzzles in just 45 minutes. Our outdoor experience.",
    tag: 'Outdoor',
  },
];
---

<Layout metadata={metadata}>
  <!-- ════════ HERO ════════ -->
  <section class="rooms-hero">
    <div class="rooms-hero-bg"></div>
    <div class="rooms-hero-content">
      <div class="rooms-badge"><span>🔍</span> Choose Your Challenge</div>
      <h1>Our <span class="text-red">Escape</span> Rooms</h1>
      <p>Six unique worlds. One way out. <em>Which will you survive?</em></p>
    </div>
  </section>

  <!-- ════════ ROOM GRID ════════ -->
  <section class="rooms-grid-section">
    <div class="rooms-grid-bg"></div>
    <div class="rooms-grid">
      {rooms.map((room) => (
        <article class="room-card" style={`--room-color: ${room.color}`}>
          <!-- Room atmosphere block -->
          <div class="room-atmo" style={`background: linear-gradient(135deg, ${room.color}15, ${room.color}05)`}>
            <span class="room-emoji">{room.icon}</span>
            {room.tag && <span class="room-tag" style={`background:${room.color}20; color:${room.color}`}>{room.tag}</span>}
          </div>

          <!-- Room info -->
          <div class="room-body">
            <div class="room-header">
              <h2>{room.name}</h2>
              <div class="room-difficulty">
                <span class="diff-dots">
                  {typeof room.difficulty === 'number' && Array.from({ length: 5 }, (_, i) => {
                    const filled = i < Math.round(room.difficulty / 2);
                    return <span class={`diff-dot${filled ? ' filled' : ''}`} style={filled ? `background:${room.color}` : ''}></span>;
                  })}
                </span>
                <span class="diff-label">Difficulty {room.difficulty}/10</span>
              </div>
            </div>

            <p class="room-story">{room.story}</p>

            <div class="room-stats">
              <div class="room-stat"><span class="room-stat-val">{room.players}</span><span class="room-stat-lbl">Players</span></div>
              <div class="room-stat"><span class="room-stat-val">{room.duration}</span><span class="room-stat-lbl">Duration</span></div>
              <div class="room-stat"><span class="room-stat-val accent">{room.price}</span><span class="room-stat-lbl">Per Person</span></div>
            </div>

            <a href="/book" class="room-book-btn">
              Book This Room
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ════════ CTA ════════ -->
  <section class="rooms-cta">
    <div class="rooms-cta-bg"></div>
    <h2>Ready to Take On a Room?</h2>
    <p>All rooms are open Thursday – Sunday. Choose your challenge and lock in your slot.</p>
    <a href="/book" class="btn-primary-hero glow-red">
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      BOOK NOW
    </a>
  </section>
</Layout>

<style is:global>
  /* ── Hero ── */
  .rooms-hero {
    position: relative; padding: 3.5rem 1.5rem 3rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .rooms-hero-bg {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(229,57,53,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: bg-drift 20s linear infinite;
  }
  @keyframes bg-drift {
    0% { background-position: 0 0; }
    100% { background-position: 48px 48px; }
  }
  .rooms-hero-content { position: relative; max-width: 36rem; margin: 0 auto; }
  .rooms-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red, #E53935);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .rooms-hero-content h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 900; color: white;
    line-height: 1.1; margin-bottom: 1rem;
  }
  .rooms-hero-content p { font-size: 1.1rem; color: #999; }
  .rooms-hero-content em { font-style: normal; color: var(--teal, #06B6D4); font-weight: 600; }

  /* ── Grid section ── */
  .rooms-grid-section {
    position: relative; padding: 3rem 1.5rem 4rem;
    background: #0d0d0d; overflow: hidden;
  }
  .rooms-grid-bg {
    position: absolute; inset: 0; opacity: 0.15;
    background-image: radial-gradient(circle, rgba(229,57,53,0.08) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .rooms-grid {
    position: relative; max-width: 68rem; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* ── Room card ── */
  .room-card {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.22,1,0.36,1);
    display: flex; flex-direction: column;
  }
  .room-card:hover {
    border-color: var(--room-color, #E53935);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.5), 0 0 0 1px color-mix(in srgb, var(--room-color, #E53935) 30%, transparent);
  }
  .room-atmo {
    height: 120px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }
  .room-emoji { font-size: 3.5rem; transition: transform 0.3s; }
  .room-card:hover .room-emoji { transform: scale(1.15); }
  .room-tag {
    position: absolute; top: 0.75rem; right: 0.75rem;
    padding: 0.2rem 0.6rem; border-radius: 999px;
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .room-body {
    padding: 1.5rem; flex: 1; display: flex; flex-direction: column;
  }
  .room-header { margin-bottom: 1rem; }
  .room-header h2 {
    font-size: 1.25rem; font-weight: 800; color: white;
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }
  .room-card:hover .room-header h2 { color: var(--room-color); }
  .room-difficulty { display: flex; align-items: center; gap: 0.5rem; }
  .diff-dots { display: flex; gap: 3px; }
  .diff-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.1);
  }
  .diff-dot.filled { background: #E53935; }
  .diff-label { font-size: 0.65rem; color: #666; font-weight: 600; text-transform: uppercase; }

  .room-story {
    font-size: 0.85rem; color: #999; line-height: 1.65;
    flex: 1; margin-bottom: 1.25rem;
  }

  .room-stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem; margin-bottom: 1.25rem;
  }
  .room-stat {
    background: rgba(255,255,255,0.03);
    border-radius: 0.6rem; padding: 0.6rem 0.4rem; text-align: center;
  }
  .room-stat-val { display: block; font-weight: 700; color: white; font-size: 0.85rem; }
  .room-stat-val.accent { color: var(--teal, #06B6D4); }
  .room-stat-lbl { font-size: 0.6rem; color: #666; text-transform: uppercase; letter-spacing: 0.08em; }

  .room-book-btn {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(255,255,255,0.04);
    color: white; font-weight: 600; font-size: 0.85rem;
    border-radius: 0.6rem;
    transition: all 0.3s;
  }
  .room-book-btn:hover {
    background: var(--room-color, #E53935);
    color: white;
  }

  /* ── CTA ── */
  .rooms-cta {
    position: relative; padding: 3.5rem 1.5rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .rooms-cta-bg {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(229,57,53,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .rooms-cta h2 {
    position: relative; font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 900; color: white; margin-bottom: 0.75rem;
  }
  .rooms-cta p {
    position: relative; font-size: 1rem; color: #999; margin-bottom: 1.5rem;
  }
  .rooms-cta .btn-primary-hero { position: relative; }

  .btn-primary-hero {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.25rem;
    background: linear-gradient(135deg, #E53935, #B71C1C);
    color: white; font-weight: 700; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: 0.6rem;
    transition: all 0.3s cubic-bezier(0.22,1,0.36,1);
    box-shadow: 0 4px 20px rgba(229,57,53,0.3);
    position: relative; overflow: hidden;
  }
  .btn-primary-hero::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.08) 50%, transparent 70%);
    transform: translateX(-100%); transition: transform 0.5s;
  }
  .btn-primary-hero:hover::after { transform: translateX(100%); }
  .btn-primary-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(229,57,53,0.45); }
</style>
