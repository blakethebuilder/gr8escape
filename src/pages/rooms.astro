---
import Layout from '~/layouts/PageLayout.astro';
import ParticleBackground from '~/components/common/ParticleBackground.astro';

const metadata = {
  title: 'Escape Rooms',
  description: '6 immersive escape rooms at The Gr8 Escape. From beginner to extreme — which will you conquer?',
};

const rooms = [
  {
    name: 'Asylum Escape', slug: 'asylum-escape', difficulty: 7, icon: '🧪', color: '#E53935',
    players: '2–8', duration: '60 min', price: 'R320',
    story: "Dr. Mulasy Tretour's office holds evidence of his vicious crimes — but one of his experiments is closer than you think. Gather the proof and get out before they get hold of you.",
  },
  {
    name: 'Trapped', slug: 'trapped', difficulty: 8, icon: '🔥', color: '#A3E635',
    players: '2–8', duration: '60 min', price: 'R320',
    story: "The Butler welcomes you to Mr. Charles A Clarence's estate. Then the smoke starts pouring in. A fire is tearing through the mansion — find another way out before you're burned alive.",
  },
  {
    name: 'The Hunted', slug: 'the-hunted', difficulty: 8.5, icon: '🌲', color: '#4CAF50',
    players: '2–8', duration: '60 min', price: 'R320',
    story: "Your uncle went quiet after months of letters from Eldertree. At his abandoned cabin the door slams shut. Movement in the woods. Can you escape the creature that's taken the town?",
  },
  {
    name: 'Nightmare', slug: 'nightmare', difficulty: 9, icon: '🌙', color: '#9C27B0',
    players: '2–8', duration: '60 min', price: 'R320',
    story: "The Dead Moon rises once a year. Tonight the Sandman walks among us. You have 60 minutes to break his curse — or join his collection of night terrors forever.",
  },
  {
    name: 'The Basement', slug: 'the-basement', difficulty: 10, icon: '⛓️', color: '#FF9800',
    players: '2–8', duration: '60 min', price: 'R320',
    story: "You wake up in darkness. Chains dragging on metal. You're pawns in a psychopath's game — 60 minutes to escape his chamber for good. Our hardest room.",
  },
  {
    name: "The Witch's Curse", slug: 'the-witchs-curse', difficulty: 'Outdoor', icon: '🧙‍♀️', color: '#7C4DFF',
    players: '2–4', duration: '45 min', price: 'R320',
    story: "Hidden within a container at The Golf Place — Fore-Ways lies a curse waiting to be broken. Solve magical puzzles in just 45 minutes. Our outdoor experience.",
  },
];

const BOOKING_URL = 'https://gr8bookings.smartintegrate.co.za/book';
---

<Layout metadata={metadata}>
  <section class="r-hero">
    <div class="r-hero-bg"></div>
    <div class="r-hero-content">
      <div class="r-badge"><span>🔍</span> Choose Your Challenge</div>
      <h1>Our <span class="text-red">Escape</span> Rooms</h1>
      <p>Six unique worlds. One way out. <em>Click any room for full details.</em></p>
    </div>
  </section>

  <section class="r-section" style="position:relative">
    <ParticleBackground particleCount={100} connectDistance={140} speed={0.4} mazeMode={true} opacity={0.8} />
    <div class="r-grid" style="position:relative;z-index:1">
      {rooms.map((room) => (
        <details class="r-card" style={`--rc:${room.color}`} id={room.slug}>
          <summary class="r-summary">
            <div class="r-photo" style={room.slug !== 'the-witchs-curse' ? `background-image:url('/assets/${room.slug === 'the-basement' ? 'basement' : room.slug}.jpg')` : `background:linear-gradient(135deg, ${room.color}20, ${room.color}08)`}>
              <div class="r-photo-overlay"></div>
              <span class="r-emoji">{room.icon}</span>
              <span class="r-diff" style={`background:${room.color}; color:white`}>
                {typeof room.difficulty === 'number' ? `${room.difficulty}/10` : room.difficulty}
              </span>
            </div>
            <div class="r-preview">
              <div class="r-preview-top">
                <h2>{room.name}</h2>
                <svg class="r-chevron" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              </div>
              <div class="r-preview-stats">
                <span>{room.players} players</span>
                <span>{room.duration}</span>
                <span class="text-lime">{room.price}/pp</span>
              </div>
            </div>
          </summary>

          <div class="r-details">
            <p class="r-story">{room.story}</p>
            <div class="r-stats-full">
              <div><span>Players</span><strong>{room.players}</strong></div>
              <div><span>Duration</span><strong>{room.duration}</strong></div>
              <div><span>Difficulty</span><strong>{typeof room.difficulty === 'number' ? `${room.difficulty}/10` : 'Outdoor'}</strong></div>
              <div><span>Price</span><strong class="text-lime">{room.price}/pp</strong></div>
            </div>
            <a href={`${BOOKING_URL}?room=${room.slug}`} target="_blank" rel="noopener noreferrer" class="r-book-btn">
              Book {room.name}
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="r-cta">
    <div class="r-cta-bg"></div>
    <h2>Ready to Take On a Room?</h2>
    <p>Open 7 days a week. Choose your challenge and lock in your slot.</p>
    <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="btn-primary-hero glow-red">
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      BOOK NOW
    </a>
  </section>
</Layout>

<style is:global>
  .r-hero {
    position: relative; padding: 5rem 1.5rem 3rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .r-hero-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(circle, rgba(229,57,53,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .r-hero-content { position: relative; max-width: 34rem; margin: 0 auto; }
  .r-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 1rem; border-radius: 999px;
    background: rgba(229,57,53,0.08); color: var(--red, #E53935);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .r-hero-content h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: white; margin-bottom: 0.75rem; }
  .r-hero-content p { font-size: 1rem; color: #999; }
  .r-hero-content em { font-style: normal; color: var(--lime, #A3E635); font-weight: 500; }

  .r-section { padding: 2rem 1.5rem 4rem; background: #0d0d0d; }
  .r-grid { max-width: 48rem; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }

  /* Card */
  .r-card {
    background: #141414; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.85rem; overflow: hidden;
    transition: all 0.25s;
  }
  .r-card[open] { border-color: var(--rc); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }

  /* Summary (always visible) */
  .r-summary {
    display: flex; cursor: pointer; list-style: none;
  }
  .r-summary::-webkit-details-marker { display: none; }

  .r-photo {
    width: 140px; flex-shrink: 0;
    background-size: cover; background-position: center;
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .r-photo-overlay {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to right, rgba(20,20,20,0.3), rgba(20,20,20,0.7));
  }
  .r-emoji { font-size: 2.5rem; position: relative; z-index: 1; }
  .r-diff {
    position: absolute; top: 0.5rem; right: 0.5rem;
    padding: 0.15rem 0.5rem; border-radius: 999px;
    font-size: 0.6rem; font-weight: 700;
  }

  .r-preview {
    flex: 1; padding: 1rem 1.25rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .r-preview-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.4rem;
  }
  .r-preview-top h2 {
    font-size: 1.05rem; font-weight: 700; color: white;
    transition: color 0.2s;
  }
  .r-card[open] .r-preview-top h2 { color: var(--rc); }
  .r-chevron { color: #555; transition: transform 0.25s; flex-shrink: 0; }
  .r-card[open] .r-chevron { transform: rotate(180deg); color: var(--rc); }

  .r-preview-stats {
    display: flex; gap: 1rem; font-size: 0.75rem; color: #888;
  }

  /* Expanded details */
  .r-details {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .r-story {
    font-size: 0.85rem; color: #aaa; line-height: 1.7;
    padding: 1rem 0; margin: 0;
  }
  .r-stats-full {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem; margin-bottom: 1rem;
  }
  .r-stats-full div {
    background: rgba(255,255,255,0.03); border-radius: 0.5rem;
    padding: 0.6rem 0.4rem; text-align: center;
  }
  .r-stats-full span { display: block; font-size: 0.6rem; color: #666; text-transform: uppercase; letter-spacing: 0.08em; }
  .r-stats-full strong { font-size: 0.85rem; color: white; font-weight: 700; }

  .r-book-btn {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.8rem; background: var(--rc); color: white;
    font-weight: 700; font-size: 0.9rem; border-radius: 0.5rem;
    text-decoration: none; transition: all 0.2s;
  }
  .r-book-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }

  /* CTA */
  .r-cta {
    position: relative; padding: 3.5rem 1.5rem;
    background: #080808; overflow: hidden; text-align: center;
  }
  .r-cta-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(circle, rgba(229,57,53,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .r-cta h2 { position: relative; font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 900; color: white; margin-bottom: 0.5rem; }
  .r-cta p { position: relative; font-size: 0.9rem; color: #999; margin-bottom: 1.25rem; }

  .btn-primary-hero {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.25rem; position: relative;
    background: linear-gradient(135deg, #E53935, #B71C1C);
    color: white; font-weight: 700; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: 0.6rem; text-decoration: none;
    transition: all 0.3s; box-shadow: 0 4px 20px rgba(229,57,53,0.3);
  }
  .btn-primary-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(229,57,53,0.45); }
</style>
