---
import Layout from '~/layouts/PageLayout.astro';

const rooms = [
  { name: 'Asylum Escape', difficulty: '7/10', img: '/assets/asylum.jpg', icon: '🧪',
    story: 'You and your team have been sent to investigate the office of Dr. Mulasy Tretour. You have 60 minutes to find a way out before they get hold of you.' },
  { name: 'Trapped', difficulty: '8/10', img: '/assets/trapped.jpg', icon: '🔥',
    story: 'Welcomed by a Butler at a wealthy gold trader\'s home, a fire breaks out. 60 minutes to escape before you are burned alive!' },
  { name: 'The Hunted', difficulty: '8.5/10', img: '/assets/hunted.jpg', icon: '🌲',
    story: 'You journey to your uncle\'s abandoned cabin. The door slams shut. Can YOU escape the creature the town has fallen to?' },
  { name: 'Nightmare', difficulty: '9/10', img: '/assets/nightmare.jpg', icon: '🌙',
    story: 'The Sandman comes out on the night of the Dead Moon. 60 minutes before he claims you as one of his night terrors forever.' },
  { name: 'The Basement', difficulty: '10/10', img: '/assets/basement.jpg', icon: '⛓️',
    story: 'Waking up in a dark basement, chains dragging. You are pawns in a psychopath\'s game — can you make it out?' },
];
---

<Layout metadata={{ title: 'Our Rooms — The Gr8 Escape' }}>
  <section class="py-20" style="background-color:#1a1a1a;background-image:url(/assets/bg-pattern.png)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Our Escape Rooms</h1>
      <p class="text-lg text-gray-300">5 unique rooms + a special outdoor experience.</p>
    </div>
  </section>

  <section class="py-20" style="background-color:#242424">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {rooms.map(r => (
          <div class="card-dark overflow-hidden">
            <div class="h-48 bg-cover bg-center" style={`background-image:url(${r.img})`}>
              <div class="w-full h-full bg-gradient-to-t from-[#1e1e1e]/90 to-transparent flex items-end p-4">
                <span class="text-4xl">{r.icon}</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-center justify-between mb-3">
                <h2 class="text-xl font-bold text-white">{r.name}</h2>
                <span class="text-xs font-bold text-accent bg-accent/10 px-2 py-1 rounded">{r.difficulty}</span>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed mb-4">{r.story}</p>
              <a href="https://thegr8escape.co.za/bookings/" target="_blank" class="btn-gr8 w-full text-center inline-block text-sm py-3">BOOK NOW</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20" style="background-color:#1a1a1a">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="card-dark overflow-hidden md:flex">
        <div class="md:w-1/3 h-64 md:h-auto bg-gradient-to-br from-purple-900/60 to-[#1a1a1a] flex items-center justify-center">
          <span class="text-7xl">🧙‍♀️</span>
        </div>
        <div class="md:w-2/3 p-8">
          <span class="text-xs font-bold text-accent bg-accent/10 px-2 py-1 rounded mb-3 inline-block">OUTDOOR EXPERIENCE</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">The Witch's Curse</h2>
          <p class="text-gray-300 mb-4">Hidden within a container at <strong class="text-white">The Golf Place — Fore-Ways</strong> lies a curse waiting to be broken. Solve magical puzzles in just <strong class="text-white">45 minutes</strong>.</p>
          <div class="grid grid-cols-3 gap-4 text-center mb-6 max-w-sm">
            <div class="bg-[#242424] rounded-lg p-3"><span class="text-red-500 font-bold block">2–4</span><span class="text-xs text-gray-400">Players</span></div>
            <div class="bg-[#242424] rounded-lg p-3"><span class="text-red-500 font-bold block">45 min</span><span class="text-xs text-gray-400">Duration</span></div>
            <div class="bg-[#242424] rounded-lg p-3"><span class="text-red-500 font-bold block">R320</span><span class="text-xs text-gray-400">Per person</span></div>
          </div>
          <a href="https://thegr8escape.co.za/bookings/" target="_blank" class="btn-gr8 inline-block">BOOK THIS ROOM</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
