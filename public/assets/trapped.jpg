    padding: 12px 15px 12px 15px;
    font-size: 12pt;
    line-height: 1.5;
    border-radius: 1.0rem;
	box-shadow: 5px 5px 5px 0px rgba(0, 0, 0, 0.8) !important;
}
	
.woocommerce #content div.product div.summary, .woocommerce div.product div.summary, .woocommerce-page #content div.product div.summary, .woocommerce-page div.product div.summary {
    box-shadow: 10px 10px 10px 0px rgba(0, 0, 0, 0.5);
	background-color: #252222D1;
	width: 100%
}


.woocommerce #content div.product div.images, .woocommerce div.product div.images, .woocommerce-page #content div.product div.images, .woocommerce-page div.product div.images {
	width: 100%;
	box-shadow: 10px 10px 10px 0px rgba(0, 0, 0, 0.5);
}

.section-content {
   padding-top: 25px;
   padding-bottom: 10px;
}

	.header--nav-position-inverse .header__nav {
		width: 10% !important;
	}

	
		.main-nav__list li {
		text-align: center !important;
		padding-top: 0px;
		padding-bottom:0px;
		border-radius: 0px;
		font-size: 12pt;
	}
	
	.main-nav__list li:hover  {
		background-color: #d73538;
		padding-top: 0px;
		padding-bottom:0px;
		border-radius: 5px;
		box-shadow: 3px 3px 3px 0px rgba(0, 0, 0, 0.5) !important;
	}

	.main-nav__list li.current-menu-item   {
		background-color: #d73538;
		padding-top: 0px;
		padding-bottom:0px;
		border-radius: 5px;
		box-shadow: 3px 3px 3px 0px rgba(0, 0, 0, 0.5) !important;
	}

	.wcpa_form_outer {
    padding: 0px 10px 0px 10px;
		margin-top: 5px;
		margin-bottom: -40px;
}
	
	.wcpa_wrap .wcpa_field_label {
    font-size: 12pt;
    padding-bottom: 10px;
}
	
	.form-control {
		border-bottom: none;
	}
	
	.wcpa_wrap .wcpa_field_wrap {
		margin-bottom: 50px;
	}
	
	.wcpa_label_pos_disable.wcpa_desc_pos_above .wcpa_field_desc {
		font-size: 12pt !important;
		padding-left: 0px;
		margin-left: 0px !important;
	}
	
	.wcpa_wrap .wcpa_checkbox {
		font-size: 11pt;
		line-height: 1.3em;
	}
	
	.wcpa_checkbox_custom {
		margin-left: 0px !important;
		margin-right: 10px !important;
	}

}




@media only screen and (max-width: 992px) {
  .header__nav--secondary {
     padding-right: 0.1rem;
	}

		.header--nav-position-inverse .header__nav {
		width: 26% !important;
	}
	
}



@media only screen and (max-width: 1200px) {
  .header__nav--secondary {
     padding-left: 0.2rem;
  }
	
	.header--nav-position-inverse .header__nav {
		width: 12% !important;
	}

	.header__logo--img {
		width: 23%;
	}
	
	.main-nav__list > li > a {
		font-size: 0.9em!important;
		align-items : center; 
		text-align: center;
		height: 50px !important;
  display: flex;
  justify-content: center;
  white-space: normal;
	}
	
	.nav-secondary > li > a {
		padding: 0px;
	}
	
	.main-nav__list li {
		text-align: center !important;
		height: auto;
	}	
	
	.main-nav__list {
		text-align: center !important;
	}

	.btn i {
		font-size:1.6em;
	}
	
	.btn-primary {
    border-radius: 7px;
    padding: 0px 5px 0px 3px;
    box-shadow: 5px 5px 5px 0px rgba(0, 0, 0, 0.5) !important;
}
	
}


@media only screen and (max-width: 1600px) {

		.header__logo--img {
		width: 28%;
	}
	
	.header--nav-position-inverse .header__nav {
		width: 26% !important;
	}

	.main-nav__list > li > a {
		font-size: 1.0em!important;
		align-items : center; 
		text-align: center;
		height: 50px !important;
  display: flex;
  justify-content: center;
  white-space: normal;

	}

	
}

